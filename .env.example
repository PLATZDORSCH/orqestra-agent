# ───────────────────────────────────────────────────────────────────────
# Orqestra environment variables — copy to `.env` and fill in.
# ───────────────────────────────────────────────────────────────────────
# `.env` is git-ignored. `config.yaml` reads these via ${VAR:-default}
# so the defaults below take effect whenever a variable is unset/empty.

# ─── LLM provider (any OpenAI-compatible API) ──────────────────────────
OPENAI_API_KEY=sk-...
# Override the API base URL (default: https://api.openai.com/v1)
# Examples:
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OPENAI_BASE_URL=http://localhost:11434/v1            # Ollama
OPENAI_BASE_URL=
# Override the default model (default: gpt-4o-mini)
# Examples:
#   OPENAI_MODEL=gpt-4o
#   OPENAI_MODEL=llama-3.3-70b-versatile
#   OPENAI_MODEL=qwen2.5-coder:14b
OPENAI_MODEL=

# ─── Web search (pick one, both are optional) ──────────────────────────
BRAVE_API_KEY=
SEARXNG_URL=

# ─── Telegram bot (optional) ───────────────────────────────────────────
# Get a token from @BotFather. Empty = Telegram gateway disabled.
TELEGRAM_BOT_TOKEN=
